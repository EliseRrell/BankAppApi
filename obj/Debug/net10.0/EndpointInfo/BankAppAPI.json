{
  "openapi": "3.0.4",
  "info": {
    "title": "BankAppAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Authenticates a user, generates a JWT token.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/register_new_customer": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Registers a new customer with user/bank account and disposition.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/issue/loan": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Issues a new loan to a customer.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueLoanDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueLoanDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/IssueLoanDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/user/{id}": {
      "put": {
        "tags": [
          "Auth"
        ],
        "summary": "Updates an existing user's email and/or password.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Retrieves a user's basic information including their role.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/userByEmail/{email}": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Retrieves a user's basic information by email.",
        "parameters": [
          {
            "name": "email",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/customers/{customerId}/full": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Retrieves customer information with accounts, loans, and transactions.",
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts": {
      "get": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Retrieves all bank accounts for customer.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts/{accountId}/transactions": {
      "get": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Retrieves all transactions for a specific account.",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "description": "The ID of the account to retrieve transactions for.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The page number (default is 1).",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of transactions per page (default is 20).",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts/{accountId}": {
      "get": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Retrieves detailed information for a specific account.",
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "description": "The ID of the account to retrieve details for.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts/create": {
      "post": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Creates a new bank account.",
        "description": "Creates a new account and links it to the customer as the owner with zero initial balance. Also uses a transaction to ensure data consistency.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts/transfer": {
      "post": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Transfers money between bank accounts.",
        "description": "Endpoint that creates two transaction records: a debit for the source account and a credit for the destination account.\r\n<param>The destination account does not need to be owned by the authenticated customer.</param><param>The response indicates whether the transfer is the same customer or a different customer.</param>",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TransferDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/CustomerAccounts/available-account-types": {
      "get": {
        "tags": [
          "CustomerAccounts"
        ],
        "summary": "Retrieves all available account types offered.",
        "description": "Endpoint that requires authentication but does not require a specific role.\r\nIt provides information about bank acount types.",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateAccountDto": {
        "required": [
          "accountTypeId"
        ],
        "type": "object",
        "properties": {
          "accountTypeId": {
            "type": "integer",
            "format": "int32"
          },
          "frequency": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "IssueLoanDto": {
        "type": "object",
        "properties": {
          "customerId": {
            "type": "integer",
            "format": "int32"
          },
          "accountId": {
            "type": "integer",
            "format": "int32"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "duration": {
            "type": "integer",
            "format": "int32"
          },
          "payments": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "transactionType": {
            "type": "string",
            "nullable": true
          },
          "transactionOperation": {
            "type": "string",
            "nullable": true
          },
          "symbol": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "givenname": {
            "type": "string",
            "nullable": true
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "gender": {
            "type": "string",
            "nullable": true
          },
          "streetaddress": {
            "type": "string",
            "nullable": true
          },
          "city": {
            "type": "string",
            "nullable": true
          },
          "zipcode": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "countryCode": {
            "type": "string",
            "nullable": true
          },
          "telephonecountrycode": {
            "type": "string",
            "nullable": true
          },
          "telephonenumber": {
            "type": "string",
            "nullable": true
          },
          "accountTypeId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "frequency": {
            "type": "string",
            "nullable": true
          },
          "initialBalance": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "dispositionType": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TransferDto": {
        "required": [
          "amount",
          "fromAccountId",
          "toAccountId"
        ],
        "type": "object",
        "properties": {
          "fromAccountId": {
            "type": "integer",
            "format": "int32"
          },
          "toAccountId": {
            "type": "integer",
            "format": "int32"
          },
          "amount": {
            "maximum": 1.7976931348623157E+308,
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          },
          "description": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "bearer": {
        "type": "http",
        "description": "JWT Authorization header using the Bearer scheme.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "bearer": [ ]
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "CustomerAccounts"
    }
  ]
}